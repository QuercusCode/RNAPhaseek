# --- Model weights (live on Hugging Face Hub, too large for GitHub) ---
model/final_model.pt
model/norm_stats.npz

# --- Internal training / metadata artifacts (kept locally only) ---
model/model_card.json
model/RESULT.md
model/den_*_summary.json

# --- Optional ensemble-member checkpoints (same policy as the main model) ---
model/ensemble/

# Any other large model files that might accidentally be added later
*.pt
*.npz

# --- Local rollback / archive artefacts ---
*.bak
rnaphaseek.py.pre-extmove.bak
split_to_external.log
archive/

# --- Python caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
build/
dist/

# --- IDE / editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# --- Claude Code session settings ---
.claude/

# --- Training logs (kept locally, not in git) ---
*.log
outputs/*.log

# --- Human transcriptome screen (large data — regenerable from scripts) ---
outputs/human_transcriptome/*.fa
outputs/human_transcriptome/*.fa.gz
outputs/human_transcriptome/*.csv
outputs/human_transcriptome/*.db
outputs/human_transcriptome/*.gtf
outputs/human_transcriptome/*.tsv
outputs/human_transcriptome/*.xlsx
outputs/human_transcriptome/*.log
outputs/human_transcriptome/chunks/
outputs/human_transcriptome/nohup.out
outputs/human_transcriptome/*.pid
outputs/human_transcriptome/run_all_chunks.sh
outputs/human_transcriptome/~$*

# --- Empty stub dirs that are runtime-only ---
Data/processed/

# --- Temporary / scratch ---
/tmp_*
*.tmp
.cache/

# --- Notebook cell outputs (re-runnable; keep clean diffs) ---
notebooks/.ipynb_checkpoints/

# --- HF Hub cache (if anyone runs locally) ---
~/.cache/huggingface/

# --- Virtual envs ---
.venv/
venv/
env/
