# --- Production weights (live on Hugging Face Hub, too large for GitHub) ---
model/production/final_model.pt
model/production/norm_stats.npz

# --- Internal training / version-tracking artifacts (kept locally only) ---
model/production/model_card.json
model/production/RESULT.md
model/production/den_*_summary.json

# Any other large model files that might accidentally be added later
*.pt
*.npz

# --- Local rollback / archive artefacts ---
*.bak
rnaphaseek.py.pre-extmove.bak
split_to_external.log
archive/

# --- Python caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
build/
dist/

# --- IDE / editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# --- Claude Code session settings ---
.claude/

# --- Training logs (kept locally, not in git) ---
*.log
outputs/*.log

# --- Empty stub dirs that are runtime-only ---
Data/processed/

# --- Temporary / scratch ---
/tmp_*
*.tmp
.cache/

# --- Notebook cell outputs (re-runnable; keep clean diffs) ---
notebooks/.ipynb_checkpoints/

# --- HF Hub cache (if anyone runs locally) ---
~/.cache/huggingface/

# --- Virtual envs ---
.venv/
venv/
env/
